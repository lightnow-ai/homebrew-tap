class LightnowProxy < Formula
  include Language::Python::Virtualenv

  desc "Local LightNow MCP proxy for centrally managed client configuration"
  homepage "https://github.com/lightnow-ai/mcp-proxy"
  url "https://github.com/lightnow-ai/mcp-proxy/releases/download/vVERSION/lightnow_proxy-VERSION.tar.gz"
  sha256 "REPLACE_WITH_RELEASE_SHA256"
  license "Apache-2.0"

  depends_on "python@3.13"

  # Add Python resources here before publishing the real formula.
  # Use a pinned resource block for every runtime dependency.

  def install
    virtualenv_install_with_resources
  end

  test do
    assert_match "LightNow MCP proxy", shell_output("#{bin}/lightnow-proxy --help")
  end
end
